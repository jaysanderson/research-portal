# ---- Server-side only (never exposed to the browser) ----
# Full Nuclia Knowledge Box base URL (.../api/v1/kb/<kbid>)
NUCLIA_KB_URL=https://aws-us-east-2-1.rag.progress.cloud/api/v1/kb/your-kb-id
# Nuclia service-account key. A manager key enables ingestion; use a reader key if you only need search/chat.
NUCLIA_API_KEY=your-service-account-jwt

# Optional: a separate reader key. If unset, NUCLIA_API_KEY is used for reads.
NUCLIA_READER_KEY=

# ---- Optional: ARAG Retrieval Agent (Sprints 5-6) ----
# If unset, the Agentic page falls back to a KB /ask-driven pipeline.
NUCLIA_ARAG_BASE_URL=
NUCLIA_ARAG_AGENT_ID=
NUCLIA_ARAG_API_KEY=

# Default generative model id (leave blank to use KB default — do NOT send empty string to /ask)
NUCLIA_GENERATIVE_MODEL=

PORT=8787
