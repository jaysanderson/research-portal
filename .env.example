# ---- Server-side only (never exposed to the browser) ----
# Primary Knowledge Box. Full base URL (.../api/v1/kb/<kbid>).
NUCLIA_KB_URL=https://aws-us-east-2-1.rag.progress.cloud/api/v1/kb/your-kb-id
NUCLIA_API_KEY=your-service-account-jwt
NUCLIA_READER_KEY=                 # optional; falls back to NUCLIA_API_KEY
NUCLIA_KB_ID=cms-dxp               # optional stable id used by the switcher
NUCLIA_KB_NAME=CMS / DXP Market    # optional display name
# Optional ARAG Retrieval Agent for the primary KB:
NUCLIA_ARAG_BASE_URL=
NUCLIA_ARAG_AGENT_ID=
NUCLIA_ARAG_API_KEY=

# ---- Optional: a SECOND Knowledge Box (multi-KB switcher) ----
# Disabled in the UI until the server can reach it.
NUCLIA_KB2_URL=https://aws-eu-central-1-1.rag.progress.cloud/api/v1/kb/your-kb2-id
NUCLIA_KB2_API_KEY=
NUCLIA_KB2_NAME=Member Knowledge
# Its ARAG Retrieval Agent (powers the Agentic function for this KB):
NUCLIA_KB2_ARAG_BASE_URL=https://aws-eu-central-1-1.dp.progress.cloud/api/v1
NUCLIA_KB2_ARAG_AGENT_ID=
NUCLIA_KB2_ARAG_API_KEY=

# Default generative model id (leave blank to use KB default — do NOT send empty string to /ask)
NUCLIA_GENERATIVE_MODEL=

PORT=8787
